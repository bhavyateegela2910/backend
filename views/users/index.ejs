<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
</head>
<body>
  <h2.>Users page</h2>
  <a href="/users/add">ADD USERS</a>
<ol>
     <% users.forEach(user => { %>
        <li> <%- user.name %>-<%= user.email %>-<%= user.role %>-,<%= user.password %>
      
        <a href="/users/<%= user._id %>/edit">Edit</a>
        <a href="/users/<%= user._id %>/delete">Delete</a>
        
        </li>
          <% }) %>
    </ol>

  
</body>
</html>