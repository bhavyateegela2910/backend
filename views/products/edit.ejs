<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
   <h2>Edit Product Form</h2>
    <form action="/products/<%= product._id %>/save" method="POST">
       <P> <input type="text" name="name" placeholder="Product Name" value="<%= product.name %>"></P>
        <P><input type="text" name="desc" placeholder="Product Description" value="<%= product.desc %>"></P>
        <P><input type="number" name="price" placeholder="Product Price" value="<%= product.price %>"></P>
        <P><input type="text" name="imageUrl" placeholder="Product Image URL" value="<%= product.imageUrl %>"></P>
        <button type="submit">Save</button> 

</body>
</html>